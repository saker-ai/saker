# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.*
!.env.example

# OS/editor noise
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
.docs/
.other/

godeps/
# Build output
bin/
/cli
workspace/
tmp/
temp/

# Third-party reference code
other/

# Local agent state
.omc/
.omx/
.cache/
.codex/
todo.txt

# Output directory
output/
outputs/

# Local test/perf artifacts (group-report logs, etc.)
.artifacts/
e2e/reports/
coverage/
coverage.out
coverage.*
*.coverprofile
profile.cov
*.prof
*.pprof
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
playwright-report/
test-results/

# Root-level build artifacts
.next/
saker-linux-amd64
/saker
/server
/run_eval
/21-openai-gateway
*.mp4

# Example binaries produced by local `go build`.
/examples/08-askuserquestion/askuserquestion
/examples/21-openai-gateway/21-openai-gateway

# Web frontend
node_modules/
web/node_modules/
web/.next/
web/out/
web/.turbo/
web/playwright-report/
web/test-results/
*.tsbuildinfo

# Web editor (OpenCut-derived sub-app)
web-editor-next/node_modules/
web-editor-next/.next/
web-editor-next/out/
web-editor-next/.turbo/
web-editor-next/playwright-report/
web-editor-next/test-results/
web-editor.legacy/

# Embedded frontend build artifacts (regenerated by `make build` / `make server`)
cmd/saker/frontend/dist/*
!cmd/saker/frontend/dist/.gitkeep
cmd/saker/editor/dist/*
!cmd/saker/editor/dist/.gitkeep
cmd/desktop/frontend/dist/*
!cmd/desktop/frontend/dist/.gitkeep

# Local SDK state (not versioned)
.saker/
.claude/
!examples/06-embed/.saker/
!examples/06-embed/.saker/**

# Local vendored modules. `godeps/aigo` is intentionally tracked because
# go.mod uses a local replace directive until aigo is published separately.
godeps/*
!godeps/aigo/
!godeps/aigo/**
godeps/aigo/.git/
godeps/aigo/.omc/
godeps/aigo/.omx/
godeps/aigo/other/
godeps/aigo/newapi_seedance_video
godeps/goim/
godeps/skillhub/

# Packages (build output)
packages/

# Stray sqlite memdb test artifacts
pkg/project/memdb_*
