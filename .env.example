# ── LLM Provider Keys ──────────────────────────────────────────
# Required for Anthropic examples and default provider detection.
ANTHROPIC_API_KEY=

# Optional provider keys.
OPENAI_API_KEY=
DASHSCOPE_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
FLUX_API_KEY=
STABILITY_API_KEY=
IDEOGRAM_API_KEY=
RECRAFT_API_KEY=
MIDJOURNEY_API_KEY=
JIMENG_API_KEY=
LIBLIB_ACCESS_KEY=
ARK_API_KEY=
KLING_API_KEY=
HAILUO_API_KEY=
LUMA_API_KEY=
RUNWAY_API_KEY=
PIKA_API_KEY=
HEDRA_API_KEY=
ELEVENLABS_API_KEY=
MINIMAX_API_KEY=
SUNO_API_KEY=
VOLC_SPEECH_ACCESS_TOKEN=
MESHY_API_KEY=
FAL_KEY=
REPLICATE_API_TOKEN=
COMFYDEPLOY_API_KEY=
RUNNINGHUB_API_KEY=
NEWAPI_API_KEY=
OPENROUTER_API_KEY=

# ── Runtime Defaults ──────────────────────────────────────────
# Default model for CLI and server mode.
SAKER_MODEL=claude-sonnet-4-5-20250929

# Server listen address (default :10112).
SAKER_HTTP_ADDR=:10112

# Data directory for persistent state (default ~/.saker).
SAKER_DATA_DIR=

# Enable debug/pprof endpoints (default false, only use in trusted environments).
SAKER_DEBUG=false

# Serve frontend from disk instead of embedded (for development).
SAKER_STATIC_DIR=

# ── Web Authentication ───────────────────────────────────────
# Set username/password for web auth (stored in settings.local.json after first run).
# SAKER_AUTH_USER=admin
# SAKER_AUTH_PASS=changeme

# ── LDAP Authentication ──────────────────────────────────────
# SAKER_LDAP_URL=ldap://localhost:389
# SAKER_LDAP_BIND_DN=cn=admin,dc=example,dc=com
# SAKER_LDAP_BIND_PASSWORD=
# SAKER_LDAP_BASE_DN=ou=users,dc=example,dc=com
# SAKER_LDAP_USER_FILTER=(uid=%s)
# SAKER_LDAP_GROUP_FILTER=(memberUid=%s)
# SAKER_LDAP_STARTTLS=false
# SAKER_LDAP_INSECURE_SKIP_VERIFY=false

# ── OIDC Authentication ──────────────────────────────────────
# SAKER_OIDC_ISSUER=https://accounts.google.com
# SAKER_OIDC_CLIENT_ID=
# SAKER_OIDC_CLIENT_SECRET=
# SAKER_OIDC_REDIRECT_URL=http://localhost:10112/api/auth/oidc/callback

# ── Gateway Mode ─────────────────────────────────────────────
# Token for gateway authentication.
# GATEWAY_TOKEN=
# Platform identifier (anthropic, openai, etc).
# GATEWAY_PLATFORM=anthropic

# ── Storage ──────────────────────────────────────────────────
# S3-compatible storage for media/artifacts.
# SAKER_STORAGE_BACKEND=embedded
# SAKER_STORAGE_S3_ENDPOINT=
# SAKER_STORAGE_S3_BUCKET=
# SAKER_STORAGE_S3_REGION=
# SAKER_STORAGE_S3_ACCESS_KEY=
# SAKER_STORAGE_S3_SECRET_KEY=

# ── CORS ─────────────────────────────────────────────────────
# Allowed origins for CORS (comma-separated, default: localhost only).
# SAKER_CORS_ALLOWED_ORIGINS=http://localhost:10111

# ── Timeout ──────────────────────────────────────────────────
# Global request timeout in milliseconds.
# SAKER_TIMEOUT_MS=0