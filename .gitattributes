# Line ending normalization
* text=auto eol=lf

# Go language detection
*.go linguist-language=Go

# Generated files
go.sum linguist-generated=true
vendor/ linguist-vendored=true

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.wav binary
*.ogg binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.7z binary
*.jar binary
*.dex binary

# Documentation
*.md linguist-language=Markdown
*.mermaid linguist-language=Mermaid

# Frontend
web/package-lock.json linguist-generated=true
web-editor-next/package-lock.json linguist-generated=true

# Large files excluded from diff stats
*.patch -diff
*.min.js -diff
*.min.css -diff